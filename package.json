{
  "name": "gist-ai",
  "version": "0.1.0",
  "description": "Memory & context compression for AI applications. Keeps the gist, drops the bulk.",
  "type": "module",
  "author": "Theresa <hapytrails2526@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hapytrails2526/gist-ai.git"
  },
  "homepage": "https://github.com/Hapytrails2526/gist-ai#readme",
  "bugs": {
    "url": "https://github.com/Hapytrails2526/gist-ai/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "gist-mcp": "dist/mcp/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "import": "./dist/mcp/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "build:wasm": "cargo build --release --manifest-path native/turboquant/Cargo.toml --target wasm32-unknown-unknown && node scripts/build-wasm.mjs",
    "demo": "tsx examples/demo.ts",
    "demo:vectors": "tsx examples/vectors.ts",
    "demo:kvcache": "tsx examples/kvcache.ts",
    "demo:compress": "tsx examples/compress.ts",
    "test:mcp": "tsx examples/mcp-test.ts",
    "demo:prose-model": "tsx examples/prose-model.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "ai",
    "llm",
    "memory",
    "context",
    "compression",
    "tokens",
    "prompt",
    "claude",
    "rag"
  ],
  "license": "MIT",
  "devDependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@types/node": "^25.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@huggingface/transformers": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    }
  }
}
